  "info": {
    "title": "Dealy API",
    "description": "Dealy production API — swipe-first, location-aware deals.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "supabase": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Supabase access token"
      }
    },
    "schemas": {
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "maxLength": 80
          },
          "graduationYear": {
            "type": "number",
            "minimum": 1950,
            "maximum": 2100
          },
          "campusId": {
            "type": "string",
            "format": "uuid"
          },
          "onboardingCompleted": {
            "type": "boolean"
          },
          "interests": {
            "description": "Category slugs",
            "maxItems": 30,
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "UpdatePreferencesDto": {
        "type": "object",
        "properties": {
          "searchRadiusMiles": {
            "type": "number",
            "minimum": 1,
            "maximum": 50
          },
          "notificationsEnabled": {
            "type": "boolean"
          }
        }
      },
      "CreateSwipeDto": {
        "type": "object",
        "properties": {
          "direction": {
            "type": "string",
            "enum": [
              "left",
              "right",
              "up"
            ],
            "description": "right also saves the deal"
          }
        },
        "required": [
          "direction"
        ]
      },
      "RegisterPushTokenDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "platform": {
            "type": "string",
            "enum": [
              "ios",
              "android",
              "web"
            ]
          }
        },
        "required": [
          "token",
          "platform"
        ]
      },
      "UpdateNotificationPrefsDto": {
        "type": "object",
        "properties": {
          "newNearbyDeals": {
            "type": "boolean"
          },
          "priceDrops": {
            "type": "boolean"
          },
          "expiringSaved": {
            "type": "boolean"
          },
          "watchedUpdates": {
            "type": "boolean"
          },
          "studentDeals": {
            "type": "boolean"
          },
          "eventReminders": {
            "type": "boolean"
          },
          "sponsored": {
            "type": "boolean"
          },
          "quietHoursStart": {
            "type": "number",
            "minimum": 0,
            "maximum": 23,
            "description": "Quiet-hours start (local hour)"
          },
          "quietHoursEnd": {
            "type": "number",
            "minimum": 0,
            "maximum": 23
          },
          "timezone": {
            "type": "string",
            "example": "America/New_York"
          }
        }
      },
      "TrackEventDto": {
        "type": "object",
        "properties": {}
      },
      "AppleSyncDto": {
        "type": "object",
        "properties": {}
      },
      "AppleWebhookDto": {
        "type": "object",
        "properties": {}
      },
      "GrantRoleDto": {
        "type": "object",
        "properties": {}
      }
    }
  }
}

// Dealy Prisma schema.
// Phase 1: datasource + PostGIS extension + a smoke model to prove migrations.
// The full domain schema (users, deals, PostGIS geography columns, etc.) is
// added incrementally in Phases 2–9. PostGIS geography columns are managed via
// raw-SQL migrations because Prisma has no native geography type (see decisions.md).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
  // The postgis/postgis image pre-creates these; declare them all so Prisma
  // treats them as managed (no false drift). Dealy only queries `postgis`.
  extensions = [postgis, postgis_topology, postgis_tiger_geocoder, fuzzystrmatch]
}

/// Phase 1 smoke model — confirms migrations + the Prisma client work end to end.
model HealthCheck {
  id        String   @id @default(uuid()) @db.Uuid
  note      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("health_checks")
}

// ===========================================================================
// Phase 2 — identity, profile, preferences, schools/campuses, categories.
// Roles live in a server-controlled table (NEVER trusted from JWT metadata).
// ===========================================================================

enum UserRole {
  user
  business_member
  business_owner
  moderator
  admin

  @@map("user_role")
}

/// App identity, linked 1:1 to a Supabase auth user by `supabaseUserId` (the JWT `sub`).
model User {
  id             String    @id @default(uuid()) @db.Uuid
  supabaseUserId String    @unique @map("supabase_user_id") @db.Uuid
  email          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  /// Soft-delete marker for account deletion (data purged by a worker job).
  deletedAt      DateTime? @map("deleted_at")

  profile             UserProfile?
  preferences         UserPreferences?
  categoryPreferences UserCategoryPreference[]
  roles               UserRoleAssignment[]
  savedDeals          SavedDeal[]
  watchedDeals        WatchedDeal[]
  swipes              DealSwipe[]
  redemptions         DealRedemption[]
  interactions        DealInteraction[]
  pushTokens          PushToken[]
  notifications       Notification[]
  notificationPrefs   NotificationPreferences?
  subscriptions       Subscription[]

  @@index([deletedAt])
  @@map("users")
}

/// Server-controlled authorization. Multiple roles per user supported.
model UserRoleAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@map("user_roles")
}

model UserProfile {
  userId              String    @id @map("user_id") @db.Uuid
  displayName         String?   @map("display_name")
  graduationYear      Int?      @map("graduation_year")
  campusId            String?   @map("campus_id") @db.Uuid
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  consentAt           DateTime? @map("consent_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  campus Campus? @relation(fields: [campusId], references: [id], onDelete: SetNull)

  @@map("user_profiles")
}

model UserPreferences {
  userId               String   @id @map("user_id") @db.Uuid
  searchRadiusMiles    Int      @default(10) @map("search_radius_miles")
  notificationsEnabled Boolean  @default(false) @map("notifications_enabled")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserCategoryPreference {
  userId     String   @map("user_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@index([categoryId])
  @@map("user_category_preferences")
}

/// Stable category taxonomy. `slug` mirrors the iOS `DealCategory` rawValue.
model Category {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  displayName String   @map("display_name")
  symbol      String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  userPreferences UserCategoryPreference[]
  deals           Deal[]

  @@map("categories")
}

// ===========================================================================
// Phase 3 — stores, deals, geospatial. `geog` is a STORED generated geography
// column (from lat/lng) with a GiST index — created via raw SQL in the
// migration because Prisma can't author generated/geography columns. It's typed
// `Unsupported` here so Prisma tracks it (no false drift) but never queries it;
// all spatial queries use raw SQL (see decisions.md ADR-003).
// ===========================================================================

enum DealStatus {
  draft
  published
  archived
  expired

  @@map("deal_status")
}

enum ModerationStatus {
  pending
  approved
  rejected

  @@map("moderation_status")
}

/// Server-controlled trust signal. NEVER trusted from a client. A deal counts as
/// shown-able only when `verified`; `unreachable` means a transient provider
/// failure (kept briefly under a grace policy), `invalid`/`expired` mean the
/// authoritative source no longer confirms the offer.
enum VerificationStatus {
  pending
  verified
  unreachable
  invalid
  expired

  @@map("verification_status")
}

/// Provenance trust tier of a deal's source. ONLY `authoritative` deals may be
/// verified, shown with a Verified badge, returned in production feeds, or
/// counted toward Atlanta coverage. `editorial` (hand-curated) and `fixture`
/// (dev/test) inventory are never source-confirmed and never enter trust paths.
enum SourceTrust {
  authoritative
  editorial
  fixture

  @@map("source_trust")
}

model Store {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  deals Deal[]

  @@map("stores")
}

model Deal {
  id                  String           @id @default(uuid()) @db.Uuid
  /// Stable provider/seed identifier for idempotent upserts + dedupe.
  externalId          String?          @unique @map("external_id")
  title               String
  merchant            String
  storeId             String?          @map("store_id") @db.Uuid
  categoryId          String           @map("category_id") @db.Uuid
  shortDescription    String           @default("") @map("short_description")
  detailedDescription String           @default("") @map("detailed_description")
  terms               String           @default("")
  /// Money as integer minor units (cents). Never floating point.
  currentPriceMinor   BigInt?          @map("current_price_minor")
  originalPriceMinor  BigInt?          @map("original_price_minor")
  currency            String           @default("USD")
  dealScore           Int              @default(50) @map("deal_score")
  isOnline            Boolean          @default(false) @map("is_online")
  isStudentOnly       Boolean          @default(false) @map("is_student_only")
  couponCode          String?          @map("coupon_code")
  destinationUrl      String?          @map("destination_url")
  redemptionBrand     String?          @map("redemption_brand")
  latitude            Float?
  longitude           Float?
  geog                Unsupported("geography(Point, 4326)")?
  locationTags        String[]         @map("location_tags")
  visualSeed          Int              @default(0) @map("visual_seed")
  status              DealStatus       @default(published)
  moderationStatus    ModerationStatus @default(approved) @map("moderation_status")
  source              String           @default("seed")
  /// Provenance trust tier. Defaults to `fixture` (the safe non-authoritative
  /// default): an unknown source is never treated as source-confirmed.
  sourceTrust         SourceTrust      @default(fixture) @map("source_trust")
  /// Source provenance: canonical URL / external identifier the deal was confirmed
  /// against, and the human-facing attribution string required by some providers.
  sourceUrl           String?          @map("source_url")
  providerAttribution String?          @map("provider_attribution")
  /// Server-controlled verification lifecycle. Defaults to `pending`; the ingest
  /// + daily re-verification jobs are the only writers. Clients never set these.
  verificationStatus  VerificationStatus @default(pending) @map("verification_status")
  lastVerifiedAt      DateTime?        @map("last_verified_at")
  lastVerificationAttemptAt DateTime?  @map("last_verification_attempt_at")
  verificationFailureReason String?    @map("verification_failure_reason")
  /// Cross-source dedup fingerprint (merchant+title+location+price+category).
  fingerprint         String?
  confidenceScore     Int?             @map("confidence_score")
  crawlSourceId       String?          @map("crawl_source_id") @db.Uuid
  crawlSource         CrawlSource?     @relation(fields: [crawlSourceId], references: [id], onDelete: SetNull)
  startAt             DateTime?        @map("start_at")
  expiresAt           DateTime         @map("expires_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  store        Store?            @relation(fields: [storeId], references: [id], onDelete: SetNull)
  category     Category          @relation(fields: [categoryId], references: [id])
  savedBy      SavedDeal[]
  watchedBy    WatchedDeal[]
  swipes       DealSwipe[]
  redemptions  DealRedemption[]
  interactions DealInteraction[]
  priceHistory PriceHistory[]
  notifications Notification[]

  @@index([status, expiresAt])
  @@index([categoryId])
  @@index([fingerprint])
  // Feed gating reads on (status, verification, expiry); re-verification sweeps on (verification, expiry).
  @@index([status, verificationStatus, expiresAt])
  @@index([verificationStatus, expiresAt])
  // Curated-in-radius feed read (editorial + approved + published).
  @@index([status, moderationStatus, expiresAt])
  @@map("deals")
}

// ===========================================================================
// Phase 6 — ingestion runs + failures (provider framework observability).
// ===========================================================================

enum IngestionStatus {
  running
  succeeded
  failed

  @@map("ingestion_status")
}

model IngestionRun {
  id         String          @id @default(uuid()) @db.Uuid
  provider   String
  status     IngestionStatus @default(running)
  fetched    Int             @default(0)
  upserted   Int             @default(0)
  deduped    Int             @default(0)
  failed     Int             @default(0)
  error      String?
  startedAt  DateTime        @default(now()) @map("started_at")
  finishedAt DateTime?       @map("finished_at")

  failures IngestionFailure[]

  @@index([provider, startedAt])
  @@map("ingestion_runs")
}

model IngestionFailure {
  id         String   @id @default(uuid()) @db.Uuid
  runId      String   @map("run_id") @db.Uuid
  externalId String?  @map("external_id")
  reason     String
  createdAt  DateTime @default(now()) @map("created_at")

  run IngestionRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("ingestion_failures")
}

/// Daily re-verification run. Mirrors IngestionRun for operational monitoring:
/// how many active deals were re-checked and what happened to them.
model VerificationRun {
  id          String          @id @default(uuid()) @db.Uuid
  provider    String
  status      IngestionStatus @default(running)
  checked     Int             @default(0)
  confirmed   Int             @default(0)
  invalidated Int             @default(0)
  expired     Int             @default(0)
  unreachable Int             @default(0)
  error       String?
  startedAt   DateTime        @default(now()) @map("started_at")
  finishedAt  DateTime?       @map("finished_at")

  outcomes VerificationOutcome[]

  @@index([provider, startedAt])
  @@map("verification_runs")
}

model VerificationOutcome {
  id         String   @id @default(uuid()) @db.Uuid
  runId      String   @map("run_id") @db.Uuid
  dealId     String?  @map("deal_id") @db.Uuid
  externalId String?  @map("external_id")
  /// confirmed | invalid | expired | unreachable
  outcome    String
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  run VerificationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("verification_outcomes")
}

// ===========================================================================
// Phase 7 — notifications, push tokens, preferences, price history.
// ===========================================================================

enum DevicePlatform {
  ios
  android
  web

  @@map("device_platform")
}

enum NotificationType {
  new_nearby_deal
  price_drop
  expiring_saved
  watched_update
  student_deal
  event_reminder
  sponsored
  account

  @@map("notification_type")
}

model PushToken {
  id         String         @id @default(uuid()) @db.Uuid
  userId     String         @map("user_id") @db.Uuid
  token      String         @unique
  platform   DevicePlatform
  invalid    Boolean        @default(false)
  lastSeenAt DateTime       @default(now()) @map("last_seen_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model NotificationPreferences {
  userId          String   @id @map("user_id") @db.Uuid
  newNearbyDeals  Boolean  @default(true) @map("new_nearby_deals")
  priceDrops      Boolean  @default(true) @map("price_drops")
  expiringSaved   Boolean  @default(true) @map("expiring_saved")
  watchedUpdates  Boolean  @default(true) @map("watched_updates")
  studentDeals    Boolean  @default(true) @map("student_deals")
  eventReminders  Boolean  @default(true) @map("event_reminders")
  sponsored       Boolean  @default(false) @map("sponsored")
  /// Local-time quiet-hours window [start, end) in 0–23; null = disabled.
  quietHoursStart Int?     @map("quiet_hours_start")
  quietHoursEnd   Int?     @map("quiet_hours_end")
  timezone        String   @default("America/New_York")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  body      String
  dealId    String?          @map("deal_id") @db.Uuid
  data      Json?
  /// Dedupe/idempotency key, e.g. "price_drop:<dealId>". Unique per user.
  dedupeKey String?          @map("dedupe_key")
  readAt    DateTime?        @map("read_at")
  sentAt    DateTime?        @map("sent_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal Deal? @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt])
  @@map("notifications")
}

model PriceHistory {
  id         String   @id @default(uuid()) @db.Uuid
  dealId     String   @map("deal_id") @db.Uuid
  priceMinor BigInt   @map("price_minor")
  recordedAt DateTime @default(now()) @map("recorded_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, recordedAt])
  @@map("price_history")
}

// ===========================================================================
// Phase 9 — subscriptions (Dealy+) + admin audit. Entitlements are computed
// SERVER-side from verified App Store transactions; the client boolean is
// never trusted.
// ===========================================================================

enum SubscriptionStatus {
  active
  expired
  in_grace
  revoked

  @@map("subscription_status")
}

model Subscription {
  id                    String             @id @default(uuid()) @db.Uuid
  userId                String             @map("user_id") @db.Uuid
  source                String             @default("app_store")
  productId             String             @map("product_id")
  status                SubscriptionStatus @default(active)
  originalTransactionId String             @unique @map("original_transaction_id")
  expiresAt             DateTime?          @map("expires_at")
  autoRenew             Boolean            @default(true) @map("auto_renew")
  environment           String             @default("sandbox")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  events SubscriptionEvent[]

  @@index([userId])
  @@map("subscriptions")
}

model SubscriptionEvent {
  id             String   @id @default(uuid()) @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  type           String
  transactionId  String?  @map("transaction_id")
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  /// Idempotency for replayed App Store notifications.
  @@unique([subscriptionId, transactionId, type])
  @@map("subscription_events")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([actorUserId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ===========================================================================
// Phase 4 — user actions. Saves/watches/redemptions are naturally idempotent
// via composite PKs; swipes are append-only with soft-undo. `idempotency_keys`
// makes unsafe POST retries safe.
// ===========================================================================

enum SwipeDirection {
  left
  right
  up

  @@map("swipe_direction")
}

enum InteractionType {
  view
  click
  share
  impression
  open

  @@map("interaction_type")
}

model SavedDeal {
  userId  String   @map("user_id") @db.Uuid
  dealId  String   @map("deal_id") @db.Uuid
  savedAt DateTime @default(now()) @map("saved_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@id([userId, dealId])
  @@index([userId, savedAt])
  @@map("saved_deals")
}

model WatchedDeal {
  userId    String   @map("user_id") @db.Uuid
  dealId    String   @map("deal_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@id([userId, dealId])
  @@index([userId])
  @@map("watched_deals")
}

model DealSwipe {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  dealId         String         @map("deal_id") @db.Uuid
  direction      SwipeDirection
  /// Saved state before this swipe, so undo restores it exactly.
  wasSavedBefore Boolean        @default(false) @map("was_saved_before")
  undone         Boolean        @default(false)
  createdAt      DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("deal_swipes")
}

/// Realized savings — counted once per (user, deal). Mirrors iOS `savingsEvents`.
model DealRedemption {
  userId       String   @map("user_id") @db.Uuid
  dealId       String   @map("deal_id") @db.Uuid
  savingsMinor BigInt   @map("savings_minor")
  currency     String   @default("USD")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@id([userId, dealId])
  @@index([userId, createdAt])
  @@map("deal_redemptions")
}

model DealInteraction {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @map("user_id") @db.Uuid
  dealId    String          @map("deal_id") @db.Uuid
  type      InteractionType
  /// Structured signals for the later personalization phase (distance bucket,
  /// freshness, price/value, category). NEVER contains precise coordinates.
  metadata  Json?
  /// Optional dedupe key, e.g. "impression:<dealId>:<yyyy-mm-dd>". Unique per
  /// user so repeated impressions of the same deal in a day collapse to one row.
  dedupeKey String?         @map("dedupe_key")
  createdAt DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([dealId, type])
  @@index([userId, createdAt])
  @@map("deal_interactions")
}

model IdempotencyKey {
  key       String   @id
  userId    String   @map("user_id") @db.Uuid
  response  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("idempotency_keys")
}

model School {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  shortName String   @map("short_name")
  createdAt DateTime @default(now()) @map("created_at")

  campuses Campus[]

  @@map("schools")
}

/// Density-first rollout zones for the Atlanta pilot. A user qualifies for the
/// Nearby pilot only when their location falls within an ENABLED zone that
/// currently meets the coverage threshold (>=20 authoritative verified
/// pilot-category physical deals within 10mi of the zone center). `enabled`
/// defaults false — zones are turned on deliberately as they reach density.
model CoverageZone {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  name        String
  latitude    Float
  longitude   Float
  /// Geographic extent of the zone (miles from center) for point-in-zone checks.
  radiusMiles Int      @default(10) @map("radius_miles")
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([enabled])
  @@map("coverage_zones")
}

/// A campus/city anchor. lat/lng are the source for the PostGIS `geog` column
/// added in Phase 3 (with a GiST index) for nearby queries.
model Campus {
  id            String   @id @default(uuid()) @db.Uuid
  schoolId      String?  @map("school_id") @db.Uuid
  slug          String   @unique
  name          String
  shortName     String   @map("short_name")
  cityContext   String   @map("city_context")
  latitude      Float
  longitude     Float
  defaultRadius Int      @default(5) @map("default_radius")
  locationTags  String[] @map("location_tags")
  createdAt     DateTime @default(now()) @map("created_at")

  school   School?       @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  profiles UserProfile[]

  @@index([schoolId])
  @@map("campuses")
}

// ===========================================================================
// Phase 8 — curated-deal crawler (crawl sources, runs, failures).
// ===========================================================================

enum CrawlKind {
  restaurant
  happy_hour
  student_discount
  grocery_circular
  local_promo

  @@map("crawl_kind")
}

model CrawlSource {
  id                  String     @id @default(uuid()) @db.Uuid
  url                 String     @unique
  kind                CrawlKind
  merchantHint        String?    @map("merchant_hint")
  defaultCategorySlug String?    @map("default_category_slug")
  zoneSlug            String?    @map("zone_slug")
  enabled             Boolean    @default(true)
  crawlIntervalHours  Int        @default(24) @map("crawl_interval_hours")
  lastCrawledAt       DateTime?  @map("last_crawled_at")
  sourceType          String     @default("merchant_site") @map("source_type")
  dealUrl             String?    @map("deal_url")
  targetPaths         String[]   @default([]) @map("target_paths")
  reliabilityScore    Int        @default(50) @map("reliability_score")
  lastSuccessAt       DateTime?  @map("last_success_at")
  averageDealsFound   Float      @default(0) @map("average_deals_found")
  createdAt           DateTime   @default(now()) @map("created_at")

  deals         Deal[]
  runs          CrawlRun[]
  contentHashes ContentHash[]
  candidates    DealCandidate[]

  @@index([enabled])
  @@map("crawl_sources")
}

model CrawlRun {
  id         String          @id @default(uuid()) @db.Uuid
  sourceId   String          @map("source_id") @db.Uuid
  status     IngestionStatus @default(running)
  fetched    Int             @default(0)
  queued     Int             @default(0)
  deduped    Int             @default(0)
  failed     Int             @default(0)
  firecrawlPages Int     @default(0) @map("firecrawl_pages")
  unchanged      Boolean @default(false)
  error      String?
  startedAt  DateTime        @default(now()) @map("started_at")
  finishedAt DateTime?       @map("finished_at")

  source   CrawlSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  failures CrawlFailure[]

  @@index([sourceId, startedAt])
  @@index([sourceId, unchanged, startedAt])
  @@map("crawl_runs")
}

model CrawlFailure {
  id        String   @id @default(uuid()) @db.Uuid
  runId     String   @map("run_id") @db.Uuid
  url       String?
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  run CrawlRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("crawl_failures")
}

// ===========================================================================
// Phase 10 — intelligent discovery foundation (Firecrawl + Gemini).
// ===========================================================================

model RegionalInventory {
  id               String    @id @default(uuid()) @db.Uuid
  regionSlug       String    @unique @map("region_slug")
  regionName       String    @map("region_name")
  regionType       String    @default("metro") @map("region_type")
  latitude         Float?
  longitude        Float?
  radiusMiles      Int       @default(10) @map("radius_miles")
  dealCount        Int       @default(0) @map("deal_count")
  lastRefresh      DateTime? @map("last_refresh")
  crawlHealth      String    @default("unknown") @map("crawl_health")
  verificationRate Float     @default(0) @map("verification_rate")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  candidates DealCandidate[]

  @@index([regionType])
  @@index([dealCount, lastRefresh])
  @@map("regional_inventories")
}

model ContentHash {
  id             String    @id @default(uuid()) @db.Uuid
  sourceUrl      String    @map("source_url")
  sourceId       String?   @map("source_id") @db.Uuid
  hash           String
  contentPreview String?   @map("content_preview")
  processedAt    DateTime? @map("processed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  source         CrawlSource?        @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  candidates     DealCandidate[]
  classifications AiClassification[]

  @@unique([sourceUrl, hash])
  @@index([hash])
  @@index([sourceId])
  @@map("content_hashes")
}

model DealCandidate {
  id                 String    @id @default(uuid()) @db.Uuid
  sourceId           String?   @map("source_id") @db.Uuid
  sourceUrl          String    @map("source_url")
  contentHashId      String?   @map("content_hash_id") @db.Uuid
  regionalInventoryId String?  @map("regional_inventory_id") @db.Uuid
  title              String
  merchant           String
  discount           String?
  categorySlug       String    @map("category_slug")
  expiration         DateTime?
  locationText       String?   @map("location_text")
  latitude           Float?
  longitude          Float?
  summary            String
  confidence         Float     @default(0)
  verificationStatus VerificationStatus @default(pending) @map("verification_status")
  fingerprint        String?
  raw                Json?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  promotedAt         DateTime? @map("promoted_at")

  source            CrawlSource?       @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  contentHash       ContentHash?       @relation(fields: [contentHashId], references: [id], onDelete: SetNull)
  regionalInventory RegionalInventory? @relation(fields: [regionalInventoryId], references: [id], onDelete: SetNull)
  classifications   AiClassification[]

  @@index([sourceId])
  @@index([contentHashId])
  @@index([regionalInventoryId])
  @@index([fingerprint])
  @@index([verificationStatus])
  @@index([promotedAt])
  @@map("deal_candidates")
}

model AiClassification {
  id             String   @id @default(uuid()) @db.Uuid
  candidateId    String?  @map("candidate_id") @db.Uuid
  contentHashId  String?  @map("content_hash_id") @db.Uuid
  task           String
  model          String
  promptHash     String   @map("prompt_hash")
  schemaVersion  String   @default("v1") @map("schema_version")
  output         Json
  confidence     Float    @default(0)
  createdAt      DateTime @default(now()) @map("created_at")

  candidate   DealCandidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  contentHash ContentHash?   @relation(fields: [contentHashId], references: [id], onDelete: SetNull)

  @@index([candidateId])
  @@index([contentHashId])
  @@index([task, model])
  @@index([promptHash])
  @@map("ai_classifications")
}

model AiCache {
  id            String   @id @default(uuid()) @db.Uuid
  cacheKey      String   @unique @map("cache_key")
  task          String
  model         String
  schemaVersion String  @default("v1") @map("schema_version")
  promptHash    String  @map("prompt_hash")
  output        Json
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  lastHitAt     DateTime? @map("last_hit_at")
  hitCount      Int      @default(0) @map("hit_count")

  @@index([task, model])
  @@index([expiresAt])
  @@map("ai_cache")
}

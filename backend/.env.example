# ============================================================================
# Dealy backend environment. Copy to `.env` and fill in. NEVER commit `.env`.
# Server-only secrets must NEVER be shipped in the iOS app.
# ============================================================================

# --- Application ---
NODE_ENV=development                 # development | test | production
APP_ENV=development                  # development | staging | production
PORT=3000
API_BASE_URL=http://localhost:3000
LOG_LEVEL=debug                      # trace|debug|info|warn|error
CORS_ALLOWED_ORIGINS=http://localhost:3000   # comma-separated; mobile uses bearer tokens

# --- Database (Postgres + PostGIS) ---
# Pooled connection for the app (Supabase: use the pooler URL, port 6543).
DATABASE_URL=postgresql://dealy:dealy@localhost:5434/dealy?schema=public
# Direct connection for migrations (Supabase: port 5432). Local: same as above.
DIRECT_DATABASE_URL=postgresql://dealy:dealy@localhost:5434/dealy?schema=public

# --- Supabase (Auth + Storage) ---
# From supabase.com → Project → Settings → API. SECRET key is server-only.
SUPABASE_URL=                        # https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=            # safe-ish anon/publishable key (client)
SUPABASE_SECRET_KEY=                 # service-role / secret key — SERVER ONLY
SUPABASE_JWKS_URL=                   # usually ${SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUD=authenticated
SUPABASE_STORAGE_BUCKET_DEALS=deal-images
SUPABASE_STORAGE_BUCKET_BUSINESS=business-assets

# --- Redis / BullMQ --- (local compose maps host 6381 → container 6379)
REDIS_URL=redis://localhost:6381
WORKER_CONCURRENCY=5

# --- Meilisearch ---
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=dealy_dev_master_key_change_me   # server-only
MEILISEARCH_DEALS_INDEX=deals

# --- Google Maps Platform (SERVER key, restricted to Geocoding + Places) ---
GOOGLE_MAPS_SERVER_API_KEY=

# --- Firebase Cloud Messaging (server delivery) ---
FIREBASE_PROJECT_ID=
# Service account JSON, base64-encoded, injected via deploy secret (not a file in repo).
FIREBASE_SERVICE_ACCOUNT_BASE64=

# --- Apple (APNs via Firebase + App Store Server API for Dealy+) ---
APPLE_BUNDLE_ID=com.dealy.app
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_BASE64=            # App Store Connect API .p8, base64; secret ref
APPLE_APPSTORE_ENV=sandbox          # sandbox | production

# --- Observability ---
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- Providers (content ingestion; optional, gated by presence) ---
TICKETMASTER_API_KEY=               # developer.ticketmaster.com (public API)
EVENTBRITE_TOKEN=                   # partner/approval; org events only

# --- Stripe (BUSINESS billing only — never consumer Dealy+) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
